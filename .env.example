# ⚠️ INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a: .env.local
# 2. Reemplaza los valores con tu configuración local
# 3. Este archivo (.env.local) NO será subido a Git (está en .gitignore)
# 4. Cada developer puede tener diferentes valores locales

# PostgreSQL Configuration
# 🔸 IMPORTANTE: Verificar tu puerto PostgreSQL (por defecto 5432)
DB_PASSWORD=your_postgres_password
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/mindpeace_db

# NextAuth Configuration
NEXTAUTH_SECRET=your_secret_key_here_change_this
NEXTAUTH_URL=http://localhost:3000

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

